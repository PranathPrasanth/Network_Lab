# Create Simulator
set ns [new Simulator]

# Open Trace File (.tr)
set tracefile [open out.tr w]
$ns trace-all $tracefile

# Set Routing Protocol to Link State
$ns rtproto LS

# Create Nodes
set n0 [$ns node]
set n1 [$ns node]
set n2 [$ns node]
set n3 [$ns node]

# Create Links
$ns duplex-link $n0 $n1 1Mb 10ms DropTail
$ns duplex-link $n1 $n2 1Mb 10ms DropTail
$ns duplex-link $n2 $n3 1Mb 10ms DropTail
$ns duplex-link $n0 $n3 2Mb 20ms DropTail

# Create UDP Agent
set udp [new Agent/UDP]
$ns attach-agent $n0 $udp

# Create Null Agent (Receiver)
set null [new Agent/Null]
$ns attach-agent $n3 $null

# Connect Agents
$ns connect $udp $null

# Create CBR Traffic
set cbr [new Application/Traffic/CBR]
$cbr set packetSize_ 512
$cbr set interval_ 0.2
$cbr attach-agent $udp

# Start and Stop Traffic
$ns at 1.0 "$cbr start"
$ns at 4.0 "$cbr stop"

# Finish Procedure
proc finish {} {
    global ns tracefile
    $ns flush-trace
    close $tracefile
    exit 0
}

# End Simulation Time
$ns at 5.0 "finish"

# Run Simulation
$ns run