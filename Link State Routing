#include <stdio.h>

int main(){
    
    int c[10][10],d[10],v[10]={0};
    int i,j,n,s,next,min;
    
    printf("enter no of nodes: ");
    scanf("%d",&n);
    
    printf("Cost Matrix: ");
    for(i=0;i<n;i++){
        for(j=0;j<n;j++){
            scanf("%d",&c[i][j]);
            
            if(c[i][j]==0){
                c[i][j]=999;
            }
        }
    }
    
    printf("enter source node: ");
    scanf("%d",&s);
    
    for(i=0;i<n;i++){
        d[i]=c[s][i];
    }
    d[s]=0;
    v[s]=1;
    
    for(i=1;i<n;i++){
        min=999;
        
        for(j=0;j<n;j++){
            if(d[j]<min && !v[j]){
                min=d[j];
                next=j;
            }
        }
        v[next]=1;
        
        for(j=0;j<n;j++){
            if(d[j]>min+c[next][j] && !v[j]){
                d[j]=min+c[next][j];
            }
        }
    }
    
    printf("Shortest distances: \n");
    for(i=0;i<n;i++){
        if(i!=s){
            printf("%d - %d : %d \n",s,i,d[i]);
        }
    }
    return 0;
}
