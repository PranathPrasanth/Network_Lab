#include<stdio.h>
#define INF 999

int main()
{
    int n,i,j,u,v,min;
    int cost[10][10],dist[10],visited[10]={0};

    printf("Enter number of nodes: ");
    scanf("%d",&n);

    printf("Enter cost matrix:\n");
    for(i=0;i<n;i++)
        for(j=0;j<n;j++)
            scanf("%d",&cost[i][j]);

    for(i=0;i<n;i++)
        dist[i]=INF;

    dist[0]=0;

    for(i=0;i<n;i++)
    {
        min=INF;
        for(j=0;j<n;j++)
        {
            if(!visited[j] && dist[j]<min)
            {
                min=dist[j];
                u=j;
            }
        }

        visited[u]=1;

        for(v=0;v<n;v++)
        {
            if(cost[u][v] && dist[v] > dist[u]+cost[u][v])
                dist[v]=dist[u]+cost[u][v];
        }
    }

    printf("Shortest distances:\n");
    for(i=0;i<n;i++)
        printf("%d -> %d = %d\n",0,i,dist[i]);
}
