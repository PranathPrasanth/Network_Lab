#include <stdio.h>

int main(){
    
    int n,i,j,k;
    
    printf("enter no of routers: ");
    scanf("%d",&n);
    
    int dist[n][n],cost[n][n];
    
    printf("Enter cost matrix: \n");
    
    for(i=0;i<n;i++){
        for(j=0;j<n;j++){
            
            printf("enter cost of %d - %d : ",i,j);
            scanf("%d",&cost[i][j]);
            dist[i][j]=cost[i][j];
        }
    }
    
    for(k=0;k<n;k++){
        for(i=0;i<n;i++){
            for(j=0;j<n;j++){
                if(dist[i][j]>dist[i][k]+dist[k][j]){
                    
                    dist[i][j]=dist[i][k]+dist[k][j];
                }
            }
        }
    }
    printf("\n");
    
    printf("Shortest distance matrix: \n");
    
    for(i=0;i<n;i++){
        for(j=0;j<n;j++){
            printf("%d\t",dist[i][j]);
        }
        printf("\n");
    }
    return 0;
}
